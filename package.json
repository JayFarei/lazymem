{
  "name": "lazymem",
  "version": "0.1.1",
  "description": "Terminal UI memory monitor for macOS dev environments",
  "type": "module",
  "license": "MIT",
  "author": "JayFarei",
  "repository": {
    "type": "git",
    "url": "https://github.com/JayFarei/lazymem.git"
  },
  "homepage": "https://github.com/JayFarei/lazymem",
  "keywords": ["memory", "monitor", "tui", "macos", "bun", "terminal", "devtools"],
  "bin": {
    "lazymem": "./bin/lazymem"
  },
  "files": [
    "bin/",
    "src/",
    "skill/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun --preload=./node_modules/@opentui/solid/scripts/preload.ts src/index.tsx",
    "start": "bun --preload=./node_modules/@opentui/solid/scripts/preload.ts src/index.tsx"
  },
  "dependencies": {
    "@opentui/core": "0.1.77",
    "@opentui/solid": "0.1.77",
    "solid-js": "1.9.11"
  }
}
